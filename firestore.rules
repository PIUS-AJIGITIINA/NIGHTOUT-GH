rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['name', 'date', 'venue', 'ownerId', 'createdAt']) &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
        data.date is string && data.date.size() > 0 && data.date.size() <= 20 &&
        data.venue is string && data.venue.size() > 0 && data.venue.size() <= 100 &&
        data.ownerId is string && data.ownerId == request.auth.uid &&
        data.createdAt is number;
    }

    match /events/{eventId} {
      allow read: if true; // Public can see events
      allow create: if isAuthenticated() && 
                    isValidEvent(incoming());
      allow delete: if isAuthenticated() && isOwner(resource.data.ownerId);
      allow update: if isAuthenticated() && isOwner(resource.data.ownerId) &&
                    isValidEvent(incoming()) &&
                    incoming().ownerId == resource.data.ownerId &&
                    incoming().createdAt == resource.data.createdAt;
    }
  }
}
