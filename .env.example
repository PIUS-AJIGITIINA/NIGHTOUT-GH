# Server configuration
PORT=3000

# GEMINI_API_KEY: Required for Gemini AI API calls and event discovery.
GEMINI_API_KEY=

# UNSPLASH_ACCESS_KEY: Used to fetch high-quality placeholder images.
UNSPLASH_ACCESS_KEY=

# EVENTBRITE_API_KEY: Used to fetch events from Eventbrite.
EVENTBRITE_API_KEY=

# YOUTUBE_API_KEY: Used to fetch event promo videos.
YOUTUBE_API_KEY=

# TICKETMASTER_API_KEY: Used to fetch events from Ticketmaster. (Optional)
TICKETMASTER_API_KEY=

# PREDICTHQ_API_KEY: Used to fetch events from PredictHQ. (Optional)
PREDICTHQ_API_KEY=

# APP_URL: The URL where this applet is hosted.
APP_URL=
