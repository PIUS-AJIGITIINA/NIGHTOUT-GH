# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# Required for backend functionality to fetch AI structured data
GEMINI_API_KEY=
EVENTBRITE_API_KEY=
YOUTUBE_API_KEY=
TICKETMASTER_API_KEY=
PREDICTHQ_API_KEY=
UNSPLASH_ACCESS_KEY=


# Server configuration
PORT=3000

# EVENTBRITE_API_KEY: Used to fetch events from Eventbrite.
# Required for NightOut GH event discovery.
EVENTBRITE_API_KEY="MY_EVENTBRITE_API_KEY"

# YOUTUBE_API_KEY: Used to fetch event promo videos.
# Required for NightOut GH event discovery.
YOUTUBE_API_KEY="MY_YOUTUBE_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
